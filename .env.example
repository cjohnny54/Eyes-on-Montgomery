# Montgomery City Responsiveness - Environment Variables Reference
# Copy these to your Vercel Project Settings > Environment Variables

# 1. Google Gemini API Key (Required for AI Insights & Natural Language Queries)
# Obtain from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Bright Data API Token (Optional - Dashboard will use Demo Mode if missing)
# Obtain from Bright Data dashboard (requires MCP scraping access)
BRIGHT_DATA_API_KEY=your_bright_data_api_key_here

# 3. Server Configuration (Internal)
# These are usually handled automatically by Vercel
# NODE_ENV=production
# PORT=3000
